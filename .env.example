BOT_TOKEN=
WEBHOOK_SECRET=
WEBHOOK_PATH=/webhook/telegram
BASE_URL=https://your-domain.example

DATABASE_URL=sqlite:///taxi_bot.db

SECRET_KEY=change-me-at-least-32-bytes-long!!
CODE_PEPPER=change-me-code-pepper-random
ADMIN_TELEGRAM_IDS=123456789,987654321

MINI_APP_URL=https://your-domain.example/admin/

# YooKassa (ЮKасса) — проверка через кнопку "Проверить платёж", без вебхуков
SHOP_ID=
SHOP_SECRET_KEY=

# Комиссия: процент от (цена_за_место × места + фикс) по направлению
COMMISSION_PERCENT=10
DEBT_WARN=5000
DEBT_RESTRICT=8000
DEBT_BLOCK=10000

DRIVER_OFFER_URL=https://example.com/offer.pdf
DRIVER_CAN_CREATE_TRIPS=false
SCHEDULED_TRIP_BOOKING_DAYS_AHEAD=60

ROUTE_RESERVE_MIN_DRIVERS=3
LOADING_REMINDER_MINUTES_BEFORE=30

# Авто-назначение следующих заказов тому же водителю при свободных местах
AUTO_ASSIGN_ENABLED=true
DIRECTION_PAGE_SIZE=10

# Очередь: ETA загрузки (минуты)
QUEUE_LOADING_SETUP_MIN=45
QUEUE_LOADING_GAP_MIN=30
QUEUE_DEFAULT_REST_MIN=0

# Подозрительный водитель (окно 30 дней)
DRIVER_DECLINES_SUSPICIOUS_30D=5
DRIVER_CANCELS_SUSPICIOUS_30D=3
DRIVER_DECLINE_RATE_SUSPICIOUS=0.55
